# Copy to .env.development.local (optional — defaults work for G2 sideload):
#   cp .env.development.example .env.development.local
#
# Dev uses RELATIVE API paths via the Vite proxy (same host as the sideload QR).
# This survives Wi‑Fi changes — only re-run `npm run qr:device` after your PC gets a new IP.

# Optional overrides (leave commented for Wi‑Fi-resilient defaults):
# VITE_VISION_ENDPOINT=/analyse-frame
# VITE_TEXT_PROMPT_ENDPOINT=/analyse-prompt
# VITE_SPEECH_ENDPOINT=/transcribe-prompt
# VITE_HTTP_CAMERA_URL=/camera/snapshot

VITE_CAMERA_MODE=http
