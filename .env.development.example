# Copy to .env.development.local and set your Mac LAN IP:
#   cp .env.development.example .env.development.local
#
# Required for G2 hardware + phone on the same Wi-Fi (not localhost).

VITE_DEV_HOST=YOUR_MAC_LAN_IP

# Vision API (Mac server in dev)
VITE_VISION_ENDPOINT=http://YOUR_MAC_LAN_IP:3000/analyse-frame

# Voice prompts (Speak prompt) — same host as vision server
VITE_SPEECH_ENDPOINT=http://YOUR_MAC_LAN_IP:3000/transcribe-prompt

# G2 mic is always 16 kHz — do not change sample rate

# HTTP camera (ESP32-CAM, Mac /camera/snapshot, etc.)
VITE_CAMERA_MODE=http
VITE_HTTP_CAMERA_URL=http://YOUR_MAC_LAN_IP:3000/camera/snapshot
