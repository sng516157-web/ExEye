# --- Recommended: Groq vision + speech (fast) with Gemini fallback ---

VISION_PROVIDER=groq
GROQ_API_KEY=your-groq-key
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_STT_MODEL=whisper-large-v3-turbo

# Gemini is used automatically if Groq vision fails (keep this key set)
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash

# Force Gemini-only vision (no Groq): VISION_PROVIDER=gemini

# Option B: Ollama on your Mac (100% free, runs locally)
# VISION_PROVIDER=ollama
# OLLAMA_MODEL=moondream
# OLLAMA_URL=http://127.0.0.1:11434

# Windows webcam for /camera/snapshot (requires ffmpeg: winget install Gyan.FFmpeg)
# If the server can't find ffmpeg on PATH, set the full path:
# FFMPEG_PATH=C:\Users\YOU\AppData\Local\Microsoft\WinGet\Packages\...\ffmpeg.exe
# WIN_CAMERA_DEVICE=USB2.0 FHD UVC WebCam

# --- Paid (optional) ---
# VISION_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o-mini

# If AI fails, return mock text instead of error on glasses
# MOCK_ON_AI_ERROR=1

# Speech STT provider (defaults to groq when GROQ_API_KEY is set)
# STT_PROVIDER=groq
# STT_LANGUAGE=en
