# --- Free options (pick one) ---

# Option A: Google Gemini (free tier at https://aistudio.google.com/apikey)
VISION_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-key
# Use 2.5 on free tier (2.0-flash often hits 429)
GEMINI_MODEL=gemini-2.5-flash

# Option B: Ollama on your Mac (100% free, runs locally)
# VISION_PROVIDER=ollama
# OLLAMA_MODEL=moondream
# OLLAMA_URL=http://127.0.0.1:11434

# Windows webcam for /camera/snapshot (requires ffmpeg: winget install Gyan.FFmpeg)
# WIN_CAMERA_DEVICE=USB2.0 FHD UVC WebCam

# --- Paid (optional) ---
# VISION_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_VISION_MODEL=gpt-4o-mini

# If AI fails, return mock text instead of error on glasses
# MOCK_ON_AI_ERROR=1
