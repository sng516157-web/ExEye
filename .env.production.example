# Used when building for Even Hub distribution (npm run build)
# Copy to .env.production.local before: npm run build && npm run pack

# Hosted vision API (HTTPS required for packaged apps)
VITE_VISION_ENDPOINT=https://api.yourdomain.com/analyse-frame

# User-local camera URL is environment-specific; often set per deployment.
VITE_CAMERA_MODE=http
VITE_HTTP_CAMERA_URL=http://192.168.4.1/capture
